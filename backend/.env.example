# Backend konfigurácia – skopírujte do .env a vyplňte

# ── PostgreSQL ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=representative
DB_USER=rep_test
DB_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────────
# Vygenerujte silný náhodný reťazec, napr.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ZMENTE_TOTO_V_PRODUKCII

# ── Server ──────────────────────────────────────────────────────
PORT=5300
NODE_ENV=development

# ── Seed (voliteľné) ────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Representative2026
ADMIN_EMAIL=admin@sepssk.sk
