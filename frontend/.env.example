# Vzor konfigurácie – skopírujte do .env.local a vyplňte hodnoty
# .env.local sa NEPRIDÁVA do git (je v .gitignore)

# ── Lokálny vývoj bez Azure AD ──────────────────────────────────
# true  = mock mode (fake data, bez prihlásenia)
# false = produkčný mode (vyžaduje Azure AD Client ID)
VITE_MOCK=true

# ── Produkčný mode – vyplňte po registrácii Azure AD app ────────
# (keď VITE_MOCK=false alebo nie je nastavené)
# VITE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# VITE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
